# ============================================================
# SHARED / REQUIRED
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://gg_user:gg_dev_password@localhost:5432/gujarati_global

# --- Redis (hot cache) ---
REDIS_URL=redis://localhost:6379

# --- Redis Queue (BullMQ for local dev) ---
REDIS_QUEUE_URL=redis://localhost:6380

# ============================================================
# API SERVICE (services/api)
# ============================================================

NODE_ENV=development
PORT=3001

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# OTP (in dev, OTP will be printed to console)
OTP_EXPIRY_SECONDS=600

# Email (dev: use Maildev or log to console)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@gujaratiglobal.com

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# Rate limiting
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000

# Media
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tiqr
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_CONTAINER_MEDIA=media
CDN_BASE_URL=http://localhost:10000/devstoreaccount1/media

# Feature flags
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_AI_MODERATION=false
FEATURE_NEARBY_DISCOVERY=false

# ============================================================
# WORKER SERVICE (services/worker)
# ============================================================

WORKER_CONCURRENCY=5

# FCM (leave empty in local dev to skip push)
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# APNs (leave empty in local dev to skip push)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=

# ============================================================
# WEB APP (apps/web)
# ============================================================

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=http://localhost:10000/devstoreaccount1/media

# ============================================================
# MOBILE APP (apps/mobile)
# ============================================================

EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1
EXPO_PUBLIC_ENVIRONMENT=development
